<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="robotiq_hande_gripper" params="prefix parent *origin">
    <xacro:property name="gripper_name" value="robotiq_hande_gripper"/>
    <link name="${prefix}${gripper_name}_base_link">
      <visual>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/visual/base.dae" scale="0.1 0.1 0.1"/>
        </geometry>
        <material name="flat_black"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/collision/base.stl" scale="0.1 0.1 0.1"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="0.91"/>
        <inertia ixx="0.002488" ixy="0" ixz="0" iyy="0.002488" iyz="0" izz="0.002663"/>
      </inertial>
    </link>
    <joint name="${prefix}${gripper_name}_base_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}${gripper_name}_base_link"/>
    </joint>
    <joint name="${prefix}finger_joint" type="prismatic">
      <parent link="${prefix}${gripper_name}_base_link"/>
      <child link="${prefix}left_finger_tip_link"/>
      <origin rpy="0 0 0" xyz="0 0 0.05715"/>
      <axis xyz="0 1 0"/>
      <limit effort="40" lower="0.0" upper="0.025" velocity="0.1"/>
      <mimic joint="${prefix}right_finger_tip_joint" multiplier="1" offset="0"/>
    </joint>
    <link name="${prefix}left_finger_tip_link">
      <visual>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/visual/wrist3.dae" scale="0.1 0.1 0.1"/>
        </geometry>
        <material name="flat_black"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/collision/wrist3.stl" scale="0.1 0.1 0.1"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>
    <joint name="${prefix}right_finger_tip_joint" type="prismatic">
      <parent link="${prefix}${gripper_name}_base_link"/>
      <child link="${prefix}right_finger_tip_link"/>
      <origin rpy="0 0 0" xyz="0 0 0.05715"/>
      <axis xyz="0 -1 0"/>
      <limit effort="40" lower="0.0" upper="0.025" velocity="0.1"/>
    </joint>
    <link name="${prefix}right_finger_tip_link">
      <visual>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/visual/wrist3.dae" scale="0.1 0.1 0.1"/>
        </geometry>
        <material name="flat_black"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://ur_description/meshes/ur10e/collision/wrist3.stl" scale="0.1 0.1 0.1"/>
        </geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>

    <ros2_control name="RobotiqHandE" type="gripper">
      <hardware>
        <plugin>ur_robot_driver/GripperHWI</plugin>
        <param name="gripper_joint_name">finger_joint</param>
      </hardware>
      <joint name="finger_joint">
        <command_interface name="position">
          <param name="min">0.0</param>
          <param name="max">0.8</param> </command_interface>
        <state_interface name="position"/>
      </joint>
    </ros2_control>

  </xacro:macro>
</robot>
